{
  "manifest_version": 3,
  "name": "YouTube Shorts Limit Tracker",
  "version": "1.0",
  "description": "Tracks the number of YouTube Shorts pages visited and shows a popup when limit is reached",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/shorts/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },    
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Shorts Tracker"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
} 